NODE_ENV=development
PORT=4000

# Provider API keys (set at least one)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
HF_API_KEY=

# Cache (optional)
REDIS_URL=
CACHE_ENABLED=false
CACHE_TTL_SECONDS=300

# Database
DATABASE_URL=./data/gateway.db

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Request handling
MAX_PROMPT_LENGTH=32000
REQUEST_TIMEOUT_MS=30000
MAX_RETRIES=2

# CORS
CORS_ORIGIN=*

LOG_LEVEL=info
