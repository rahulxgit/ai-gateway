NODE_ENV=development
PORT=4000

# Provider API keys (set at least one)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
HF_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=
# DEEPSEEK_API_KEY: 5M free tokens on signup (no card), then ~$0.14/1M tokens.
# KIMI_API_KEY: requires a minimum $1 recharge to activate, then cheap after.
# CEREBRAS_API_KEY: genuinely free, no card, 1M tokens/day (resets daily),
#   extremely fast wafer-scale inference. Sign up at cloud.cerebras.ai.
# MISTRAL_API_KEY: free "Experiment" tier, no card, ~1B tokens/month,
#   includes Codestral for coding. Sign up at console.mistral.ai.
# For a genuinely $0 alternative to DeepSeek/Kimi specifically, use
# OPENROUTER_API_KEY (free to create) and set model to a ":free"-suffixed
# variant, e.g. "deepseek/deepseek-chat-v3.1:free" or "moonshotai/kimi-k2:free"
# — pass it as the `model` field on a request with forceProvider=openrouter.

# Cache (optional)
REDIS_URL=
CACHE_ENABLED=false
CACHE_TTL_SECONDS=300

# Database
DATABASE_URL=./data/gateway.db

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Request handling
MAX_PROMPT_LENGTH=32000
REQUEST_TIMEOUT_MS=30000
MAX_RETRIES=2

# CORS
CORS_ORIGIN=*

LOG_LEVEL=info
